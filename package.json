{
  "name": "@naskot/node-hmac-auth",
  "version": "0.1.1",
  "description": "Simple and reusable HMAC auth for Node.js APIs (Express-friendly, framework-agnostic core).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "dev:test": "vitest",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run check && npm run test && npm run build"
  },
  "keywords": [
    "hmac",
    "auth",
    "express",
    "redis",
    "api"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
